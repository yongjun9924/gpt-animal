{
  "openapi": "3.1.0",
  "info": {
    "title": "GPT Animal Test - Result Generator",
    "description": "Generates a shareable result page URL from animal personality analysis",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://gpt-animal.vercel.app"
    }
  ],
  "paths": {
    "/api/generate-result": {
      "post": {
        "operationId": "generateResult",
        "summary": "Generate a result page URL with the animal analysis data",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["animal", "emoji", "title", "description", "traits", "compatibility"],
                "properties": {
                  "animal": {
                    "type": "string",
                    "description": "Animal name in Korean (e.g., 수달, 고양이)"
                  },
                  "emoji": {
                    "type": "string",
                    "description": "Animal emoji (e.g., 🦦, 🐱)"
                  },
                  "title": {
                    "type": "string",
                    "description": "One-line title describing the user (e.g., 호기심 많은 수달)"
                  },
                  "description": {
                    "type": "string",
                    "description": "Detailed description of why this animal matches (3-4 sentences in Korean)"
                  },
                  "traits": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "3-5 personality traits in Korean"
                  },
                  "compatibility": {
                    "type": "object",
                    "required": ["good", "bad"],
                    "properties": {
                      "good": {
                        "type": "string",
                        "description": "Compatible animal with emoji (e.g., 🐬 돌고래)"
                      },
                      "bad": {
                        "type": "string",
                        "description": "Incompatible animal with emoji (e.g., 🐱 고양이)"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully generated result URL",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string",
                      "description": "The shareable result page URL"
                    },
                    "message": {
                      "type": "string",
                      "description": "Instruction message to share with the user"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          }
        }
      }
    }
  }
}
